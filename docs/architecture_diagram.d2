direction: right

slack_user: "Slack User" { shape: person }
slack_app: "Slack App" { shape: cloud }

subgraph "Attendance Automation Platform" {
  direction: right

  fastapi_app: "FastAPI App" { shape: hexagon }
  celery_worker: "Celery Worker" { shape: hexagon }
  
  subgraph "Database" {
    db: "PostgreSQL" { shape: cylinder }
  }
  
  redis: "Redis" { shape: octagon }
  
  fastapi_app <-> db: "ORM (SQLAlchemy)"
  fastapi_app <-> redis: "Celery Broker"
  celery_worker <-> redis: "Celery Broker"
  celery_worker <-> db: "ORM (SQLAlchemy)"
}

marsos: "MarsOS" { shape: cloud }

slack_user -> slack_app: "Posts Start Report"
slack_app -> fastapi_app: "Slack Events API (Webhook)"

fastapi_app -> celery_worker: "Queue Task"

celery_worker -> marsos: "Start Attendance (API/Playwright)"

marsos <-> slack_user: "(Indirectly via MarsOS UI)"

fastapi_app -> slack_app: "Reply in Slack (Webhook)"
celery_worker -> slack_app: "Reply in Slack (Webhook)"
