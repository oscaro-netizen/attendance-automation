# --- Slack -------------------------------------------------------------------
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_BOT_TOKEN=xoxb-your_slack_bot_token
# Channel employees post their daily start report in. Leave unset to accept DMs only.
SLACK_CHANNEL_ID=C0123456789
# Reject requests whose Slack timestamp is older than this (replay protection).
SLACK_REQUEST_TIMESTAMP_TOLERANCE_SECONDS=300
# How long a processed event_id is remembered in Redis for deduplication.
SLACK_EVENT_DEDUPE_TTL_SECONDS=600
# Allow employees to run \end and post start reports in a DM with the bot.
SLACK_ALLOW_DIRECT_MESSAGES=true

# --- Infrastructure ----------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/attendance_db
# Log every SQL statement. Leave false outside local debugging.
DATABASE_ECHO=false
REDIS_URL=redis://redis:6379/0

# --- MarsOS ------------------------------------------------------------------
MARSOS_BASE_URL=https://marsos.example.com
# "playwright" (browser automation) or "api". The API provider is not
# implemented yet and will raise if selected.
MARSOS_PROVIDER=playwright
MARSOS_API_KEY=

# --- Playwright --------------------------------------------------------------
PLAYWRIGHT_HEADLESS=true
# Persisted browser storage state. Must point at shared storage if you run more
# than one worker replica, otherwise set PLAYWRIGHT_SESSION_REUSE=false.
PLAYWRIGHT_SESSION_DIR=sessions
PLAYWRIGHT_SESSION_REUSE=true
# Where failure screenshots are written.
PLAYWRIGHT_ARTIFACT_DIR=artifacts

# --- Security ----------------------------------------------------------------
# Required. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_key
# Required to enable the /employees and /attendance admin endpoints; when unset
# those endpoints return 503 rather than being left open.
ADMIN_API_KEY=a_long_random_string

# --- Business rules ----------------------------------------------------------
# IANA timezone defining the company's calendar day.
ATTENDANCE_TIMEZONE=UTC
