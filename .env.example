# --- Slack -------------------------------------------------------------------
# The only Slack credential needed. This service never posts messages, so there
# is no bot token and no chat:write scope.
# Slack app -> Basic Information -> Signing Secret
SLACK_SIGNING_SECRET=your_slack_signing_secret

# Restrict processing to one channel. Leave empty to accept any conversation the
# Slack app is subscribed to.
SLACK_CHANNEL_ID=

# How old a signed Slack request may be before it is treated as a replay.
SLACK_TIMESTAMP_TOLERANCE_SECONDS=300

# --- TimeTrack ---------------------------------------------------------------
TIMETRACK_BASE_URL=https://time.marsos.io
TIMETRACK_TIMEOUT_SECONDS=15

# --- Storage -----------------------------------------------------------------
# SQLite file holding the Slack-user -> TimeTrack-token mapping.
DATABASE_PATH=data/employees.db

# --- Misc --------------------------------------------------------------------
# Serves /docs, /redoc and the OpenAPI schema. Leave false anywhere reachable
# from the internet.
ENABLE_API_DOCS=false
LOG_LEVEL=INFO
